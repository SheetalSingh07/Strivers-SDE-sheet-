class Solution {
public:
    string reverseWords(string s) {
        int i =0;
        string word;
        string ans;
        vector<string> words;
        while(i < s.length()){
            while(i < s.length() && s[i] != ' '){
                word = word + s[i];
                i++;
            }
            while(i < s.length() && s[i] == ' '){
                i++;
            }
            if(word != "")
            words.push_back(word);
            word = "";

        }
         reverse(words.begin(),words.end());
         for(int i = 0; i < words.size(); i++){
            ans += words[i];
            if(i != words.size() - 1)
            ans += " ";
        }
         return ans;   
        
    }
};
