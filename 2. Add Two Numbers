/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
        ListNode* h1 = l1;
        ListNode* h2 = l2;
        ListNode* ans = new ListNode();
        ListNode* returnAns = ans;
        int carry =0, digit = 0;
        
        while(h1 || h2 || carry){
            int x = (h1 ? h1->val:0);
            int y = (h2 ? h2->val:0);
            int sum = x + y + carry;
             digit = sum % 10;
             carry = sum / 10;
             ans->next = new ListNode(digit);
             ans= ans->next;
             if(h1) h1= h1 -> next;
             if(h2) h2= h2 -> next;
        }
        return returnAns->next;
    }
};
