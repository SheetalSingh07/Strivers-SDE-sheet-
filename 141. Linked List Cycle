/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(NULL) {}
 * };
 */
class Solution {
public:
    bool hasCycle(ListNode *head) {
        // ListNode *slow = head;
        // ListNode *fast = head;
        // //ListNode node = head;
        // while(slow && fast && fast->next ){
        //     slow = slow->next;
        //     fast = fast->next->next;
        //     if(slow == fast ){
        //         return true;
        //     }
        // }
        // return false;

        unordered_set<ListNode*> visit;
        ListNode* curr = head;
        while(curr){
           if(visit.find(curr) != visit.end()){
            return true;
           }
           visit.insert(curr);
           curr=curr->next;
        }
        return false;
    }
};
